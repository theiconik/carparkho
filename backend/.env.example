# Copy this to .env and fill in the values

# OpenRouter API key — required for LLM explanations
# Without this, explanations fall back to a template string
OPENROUTER_API_KEY=sk-or-...

# Optional: model and HTTP settings (defaults shown)
# OPENROUTER_MODEL=google/gemini-2.0-flash-001
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
# OPENROUTER_TIMEOUT_SECONDS=30

# Comma-separated origins for CORS (default: local Next.js ports)
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Logging: DEBUG shows full OpenRouter JSON responses (no secrets logged)
# LOG_LEVEL=INFO

# Optional: override dataset paths (defaults: backend/ directory JSON files)
# CARS_DATASET_PATH=/absolute/path/to/cars-dataset.json
# QUESTIONS_CONFIG_PATH=/absolute/path/to/questions-config.json
# SCORING_CONFIG_PATH=/absolute/path/to/scoring-config.json
